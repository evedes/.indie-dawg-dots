[user]
    name = {{GIT_NAME}}
    email = {{GIT_EMAIL}}
[core]
    editor = {{GIT_EDITOR}}
[alias]
  fixup = "!git log -n 50 --pretty=format:'%h %s' --no-merges | fzf | cut -c -7 | xargs -o git commit --fixup"
[pull]
    rebase = true
[init]
    defaultBranch = main
[url "git@github.com:"]
	insteadOf = https://github.com/

